{
  "name": "getcanopy",
  "version": "0.2.0",
  "description": "Veyr terminal CLI — usage/cost, Graphify graph status, and agent guidance rules, read from local Veyr data. No proxy, no account.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hethb/Veyr.git",
    "directory": "packages/cli"
  },
