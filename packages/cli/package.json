    "llm",
    "claude-code",
    "cost",
    "observability",
    "cli",
    "veyr"
  ],
  "type": "module",
  "bin": {
    "veyr": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
