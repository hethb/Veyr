{
  "name": "getcanopy",
  "version": "0.2.3",
  "description": "Veyr terminal CLI — usage/cost, Graphify graph status, and agent guidance rules, read from local Veyr data. No proxy, no account.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hethb/Veyr.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "llm",
    "claude-code",
    "cost",
    "observability",
    "cli",
    "veyr"
  ],
  "type": "module",
  "bin": {
    "veyr": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mjs && node scripts/copy-graph-embed.mjs",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node scripts/build.mjs && node scripts/copy-graph-embed.mjs"
  },
  "devDependencies": {
    "@clack/prompts": "^1.7.0",
    "@types/node": "^22.7.0",
    "@veyr/core": "*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
