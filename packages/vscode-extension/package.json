{
  "name": "veyr-vscode",
  "displayName": "Veyr",
  "description": "LLM cost attribution and optimization suggestions in your editor, plus one-click routing of Claude Code through the Veyr proxy.",
  "version": "0.2.1",
  "private": true,
  "publisher": "veyr",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "veyr",
          "title": "Veyr",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "veyr": [
        {
          "id": "veyr.panel",
          "name": "Cost & Suggestions",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "veyr.refresh",
        "title": "Veyr: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "veyr.routeClaudeCode",
        "title": "Veyr: Route Claude Code through proxy"
      },
      {
        "command": "veyr.unrouteClaudeCode",
        "title": "Veyr: Stop routing Claude Code through proxy"
      },
      {
        "command": "veyr.openDashboard",
        "title": "Veyr: Open dashboard"
      },
      {
        "command": "veyr.openGraph",
        "title": "Veyr: Open graph visualization"
      },
      {
        "command": "veyr.showPanel",
        "title": "Veyr: Show panel"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "veyr.refresh",
          "when": "view == veyr.panel",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Veyr",
      "properties": {
        "veyr.proxyUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "Base URL of your Veyr proxy."
        },
        "veyr.dashboardUrl": {
          "type": "string",
          "default": "http://localhost:5173/dashboard",
          "description": "URL of the Veyr dashboard."
        },
        "veyr.agentStatusPath": {
          "type": "string",
          "default": "~/.veyr/agent-status/VEYR_STATUS.json",
          "description": "Path to the Veyr agent status feed written by the Veyr menu bar app."
        },
        "veyr.showCostInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the live session cost in the status bar."
        },
        "veyr.pollIntervalSeconds": {
          "type": "number",
          "default": 10,
          "minimum": 2,
          "description": "How often to re-read the Veyr agent status feed."
        },
        "veyr.autoInjectClaudeMd": {
          "type": "boolean",
          "default": true,
          "description": "Append Veyr spend status to your project's CLAUDE.md so Claude Code reads it automatically. Mirrors the Veyr menu bar app setting (shared via ~/.veyr/config.json); the menu bar app performs the updates."
        },
        "veyr.suppressModelSuggestions": {
          "type": "boolean",
          "default": false,
          "description": "Never show the inline 'switch to a cheaper model' suggestion messages."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
