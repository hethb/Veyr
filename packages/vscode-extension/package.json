{
  "name": "promptlens-vscode",
  "displayName": "Canopy",
  "description": "LLM cost attribution and optimization suggestions in your editor, plus one-click routing of Claude Code through the Canopy proxy.",
  "version": "0.1.0",
  "private": true,
  "publisher": "promptlens",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./src/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "promptlens",
          "title": "Canopy",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "promptlens": [
        {
          "id": "promptlens.panel",
          "name": "Cost & Suggestions",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "promptlens.refresh",
        "title": "Canopy: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "promptlens.routeClaudeCode",
        "title": "Canopy: Route Claude Code through proxy"
      },
      {
        "command": "promptlens.unrouteClaudeCode",
        "title": "Canopy: Stop routing Claude Code through proxy"
      },
      {
        "command": "promptlens.openDashboard",
        "title": "Canopy: Open dashboard"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "promptlens.refresh",
          "when": "view == promptlens.panel",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Canopy",
      "properties": {
        "promptlens.proxyUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "Base URL of your Canopy proxy."
        },
        "promptlens.dashboardUrl": {
          "type": "string",
          "default": "http://localhost:5173/dashboard",
          "description": "URL of the Canopy dashboard."
        }
      }
    }
  },
  "scripts": {
    "build": "echo 'No build step — open this folder in VSCode and press F5, or package with vsce.'"
  }
}
