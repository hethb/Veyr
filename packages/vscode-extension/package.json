{
  "name": "veyr-vscode",
  "displayName": "Veyr",
  "description": "LLM cost attribution and optimization suggestions in your editor, plus one-click routing of Claude Code through the Veyr proxy.",
  "version": "0.1.0",
  "private": true,
  "publisher": "veyr",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./src/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "veyr",
          "title": "Veyr",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "veyr": [
        {
          "id": "veyr.panel",
          "name": "Cost & Suggestions",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "veyr.refresh",
        "title": "Veyr: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "veyr.routeClaudeCode",
        "title": "Veyr: Route Claude Code through proxy"
      },
      {
        "command": "veyr.unrouteClaudeCode",
        "title": "Veyr: Stop routing Claude Code through proxy"
      },
      {
        "command": "veyr.openDashboard",
        "title": "Veyr: Open dashboard"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "veyr.refresh",
          "when": "view == veyr.panel",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Veyr",
      "properties": {
        "veyr.proxyUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "Base URL of your Veyr proxy."
        },
        "veyr.dashboardUrl": {
          "type": "string",
          "default": "http://localhost:5173/dashboard",
          "description": "URL of the Veyr dashboard."
        }
      }
    }
  },
  "scripts": {
    "build": "echo 'No build step — open this folder in VSCode and press F5, or package with vsce.'"
  }
}
