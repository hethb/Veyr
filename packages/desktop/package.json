{
  "name": "@promptlens/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Veyr desktop app (Electron): auto-starts the proxy and opens the dashboard with a menu-bar spend readout.",
  "author": "Veyr <hjbhatt@andrew.cmu.edu>",
  "homepage": "https://github.com/hethb/PromptLens",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:deps": "npm run build --workspace=@promptlens/proxy && VITE_PROXY_URL= npm run build --workspace=@promptlens/dashboard",
    "start": "npm run build && electron .",
    "app": "npm run build:deps && npm run build && electron .",
    "icons": "node scripts/make-icons.js",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --mac --win --linux"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.3.9",
    "express": "^4.21.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.2"
  }
}
