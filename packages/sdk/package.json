{
  "name": "canopy-sdk",
  "version": "0.1.1",
  "description": "Drop-in SDK for the Canopy proxy. Routes OpenAI and Anthropic calls through Canopy for cost observability.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hethb/PromptLens.git",
    "directory": "packages/sdk"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "keywords": [
    "openai",
    "anthropic",
    "llm",
    "observability",
    "proxy",
    "cost",
    "canopy"
  ],
  "devDependencies": {
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18"
  }
}
