{
  "manifest_version": 3,
  "name": "Veyr",
  "version": "0.4.0",
  "description": "Live token/cost estimates, prompt-optimization tips, and personalized rewrites on ChatGPT and Claude, plus your Veyr proxy data.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://promptlens.fly.dev/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Veyr",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
