# PromptLens runs zero-config by default: keys/requests are stored in a local
# SQLite file (packages/proxy/.promptlens/data.db). No external database or
# login is required. Everything below is optional.

# Proxy
PORT=3001
# OpenAI-compatible upstream (OpenAI, Groq, Ollama, ...). Groq is free for local dev.
OPENAI_UPSTREAM_URL=https://api.groq.com/openai/v1/chat/completions
# Persist full prompt content (off by default for privacy)
STORE_PROMPTS=false
# Comma-separated allowed dashboard origins for CORS
DASHBOARD_ORIGIN=http://localhost:5173
# Compress prompts on every request when true
ENABLE_COMPRESSION=false
# Allow anonymous local traffic (no x-promptlens-key) and attribute it to the
# default key. Enables routing Claude Code / other tools through the proxy.
PROMPTLENS_ALLOW_ANON=false
# Override the SQLite location if you like (defaults to packages/proxy/.promptlens/data.db)
# PROMPTLENS_DB_PATH=/absolute/path/to/data.db

# Upstream provider key used by the smoke test / demo (passed as the Bearer token)
GROQ_API_KEY=

# Dashboard (Vite)
VITE_PROXY_URL=http://localhost:3001
