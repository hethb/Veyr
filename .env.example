# PromptLens runs zero-config by default: keys/requests are stored in a local
# SQLite file (packages/proxy/.promptlens/data.db). No external database or
# login is required. Everything below is optional.

# Proxy
PORT=3001
# OpenAI-compatible upstream (OpenAI, Groq, Ollama, ...). Groq is free for local dev.
OPENAI_UPSTREAM_URL=https://api.groq.com/openai/v1/chat/completions
# Persist full prompt content (off by default for privacy). Also gates raw
# (draft -> final) pairs stored for prompt personalization; with it off, only
# metadata labels are kept. See docs/prompt-personalization.md.
STORE_PROMPTS=false
# Let the personalization endpoint generate an LLM rewrite from a user's own
# exemplars (off by default — it sends prompt text to the upstream). Retrieval
# itself is fully local and needs no flag.
ENABLE_PROMPT_REWRITE=false
# Model + key for rewrites (key falls back to GROQ_API_KEY / OPENAI_API_KEY).
REWRITE_MODEL=gpt-4o-mini
REWRITE_API_KEY=
# Comma-separated allowed dashboard origins for CORS
DASHBOARD_ORIGIN=http://localhost:5173
# Compress prompts on every request when true
ENABLE_COMPRESSION=false
# Allow anonymous local traffic (no x-promptlens-key) and attribute it to the
# default key. Enables routing Claude Code / other tools through the proxy.
PROMPTLENS_ALLOW_ANON=false

# --- Auth (optional; for hosted/multi-tenant deployments) ------------------
# When true, dashboard /api routes require a Supabase access token and data is
# scoped per user. Leave false for zero-config local single-tenant mode.
AUTH_ENABLED=false
# Supabase project URL + anon (public) key, used to verify dashboard sessions.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Override the SQLite location if you like (defaults to packages/proxy/.promptlens/data.db)
# PROMPTLENS_DB_PATH=/absolute/path/to/data.db

# Upstream provider key used by the smoke test / demo (passed as the Bearer token)
GROQ_API_KEY=

# Dashboard (Vite)
VITE_PROXY_URL=http://localhost:3001
# Auth (optional). Set all three to enable magic-link login in the dashboard.
VITE_AUTH_ENABLED=false
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
