# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=   # proxy uses this to write to DB
SUPABASE_ANON_KEY=           # dashboard uses this for auth

# Proxy
PORT=3001
# Optional: set to "true" to persist full prompt content (off by default for privacy)
STORE_PROMPTS=false
# Comma-separated list of allowed dashboard origins for CORS
DASHBOARD_ORIGIN=http://localhost:5173

# Dashboard
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_PROXY_URL=http://localhost:3001
