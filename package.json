{
  "name": "promptlens",
  "version": "0.1.0",
  "private": true,
  "description": "Drop-in LLM cost observability and optimization proxy",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:dashboard": "npm run dev --workspace=@promptlens/dashboard",
    "build": "npm run build --workspaces --if-present",
    "build:dashboard": "npm run build --workspace=@promptlens/dashboard"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "openai": "^6.42.0"
  }
}
